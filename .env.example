QUAZAR_MASTER_KEY=QUAZAR_MASTER_KEY_2026
# Секрет для межузловых запросов (GET /events, GET /blocks, POST /events/gossip)
QUAZAR_NODE_SECRET=QUAZAR_NODE_SECRET_2026
# Отдельный секрет для reg_sig (CitizenAdded); НЕ должен совпадать с QUAZAR_NODE_SECRET
QUAZAR_REG_SECRET=QUAZAR_REG_SECRET_2026
DATABASE_URL=postgres://quazar:quazar@localhost:5432/quazar
QUAZAR_NODE_ID=QZ-NODE
QUAZAR_NODE_URL=http://localhost:8080
QUAZAR_PORT=8080

# Тестовые API-ключи (test_citizen, buyer, seller)
QUAZAR_INIT_TEST_KEYS=true

# Дополнительные ключи: ключ:Роль:имя_гражданина (через запятую)
# QUAZAR_API_KEYS=my_key:Citizen:alice,my_key2:Guardian:bob

# Создание блоков (сбор pending со всех узлов сети)
QUAZAR_BLOCK_MIN_EVENTS=3
QUAZAR_BLOCK_MAX_WAIT_SECS=30
QUAZAR_SYNC_INTERVAL_SECS=60

# CORS: список origins через запятую; * = permissive; без значения = dev defaults (localhost)
# При QUAZAR_STRICT_SECRETS=true без CORS_ORIGINS cross-origin отключён
# QUAZAR_CORS_ORIGINS=http://localhost:3000,https://app.example.com

# QUAZAR_STRICT_SECRETS=true — падать при дефолтных master/node secret (prod)
# QUAZAR_DISABLE_MASTER_KEY=true — отключить мастер-ключ на узле
# API-ключи хранятся в PostgreSQL (таблица api_keys); env-ключи синхронизируются при старте
QUAZAR_RATE_LIMIT_RPS=60

# Пиры при старте (формат: id@url,id2@url2)
# QUAZAR_BOOTSTRAP_PEERS=QZ-NODE-2@http://localhost:8081